# Copy this file to .env and fill in your values
# Never commit .env to git

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
POSTGRES_URL=postgresql+asyncpg://postgres:cfdbot123@localhost:5432/cfdbot

# Scanning
SCAN_INTERVAL_SECONDS=5
DEFAULT_TIMEFRAME=1h
HTF_TIMEFRAME=4h

# Signal confluence (min score out of 12 to fire a signal)
MIN_SIGNAL_SCORE=7

# Risk management defaults (users can override via /settings)
ACCOUNT_BALANCE=10000
RISK_PERCENT=1.5
SL_ATR_MULTIPLIER=1.5
RISK_REWARD_1=1.5
RISK_REWARD_2=2.5
RISK_REWARD_3=4.0

# Active instruments (comma-separated, must have matching YAML in config/instruments/)
ACTIVE_INSTRUMENTS=XAUUSD,US30,EURUSD

# Copy this file to .env and fill in your values
# Never commit .env to git

# Required
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OWNER_CHAT_ID=your_telegram_user_id
POSTGRES_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Optional — leave empty to disable channel broadcasting
BROADCAST_CHANNEL_ID=

# Scanning interval in minutes (default: 60)
SCAN_INTERVAL_MINUTES=60

# Timeframes
DEFAULT_TIMEFRAME=1h
HTF_TIMEFRAME=4h

# Risk management defaults (users can override via /balance and /risk)
ACCOUNT_BALANCE=10000
RISK_PERCENT=1.5
SL_ATR_MULTIPLIER=1.5
RR1=1.5
RR2=2.5
RR3=4.0
